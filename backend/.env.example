PORT=5000
NODE_ENV=development

# Database (Supabase Pooler Connection String)
# Example: postgres://postgres.your-project-id:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgres://user:password@pooler-host:6543/postgres?pgbouncer=true

# Database (Supabase API for standard JS Client)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Vision Engine (Gemini) - Triple Redundancy
GEMINI_API_KEY_1=your-gemini-key-1
GEMINI_API_KEY_2=your-gemini-key-2
GEMINI_API_KEY_3=your-gemini-key-3
GEMINI_VISION_MODEL=gemini-1.5-pro

# AI Conversation Engine (Groq) - Triple Redundancy
GROQ_API_KEY_1=your-groq-key-1
GROQ_API_KEY_2=your-groq-key-2
GROQ_API_KEY_3=your-groq-key-3
GROQ_CONVERSATION_MODEL=llama3-70b-8192

# Authentication
JWT_SECRET=your-secure-jwt-secret
